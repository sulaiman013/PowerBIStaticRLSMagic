			        ABS ( _v ) >= 1000, FORMAT ( _v / 1000, "$0" ) & "K",
			        FORMAT ( _v, "$0" ) )
			VAR _chipTxt = IF ( ISBLANK ( _delta ), "n/a", FORMAT ( _delta, "+0.0%;(0.0%);0.0%" ) )
			VAR _pos = NOT ISBLANK ( _delta ) && _delta >= 0
			VAR _chipBg = IF ( ISBLANK ( _delta ), "rgb(241,245,249)", IF ( _pos, "rgb(220,242,229)", "rgb(250,226,226)" ) )
			VAR _chipFg = IF ( ISBLANK ( _delta ), "rgb(100,116,139)", IF ( _pos, "rgb(21,128,61)", "rgb(185,28,28)" ) )
			RETURN
