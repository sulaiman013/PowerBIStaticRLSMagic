	/// KPI tile (HTML): host in an HTML Content visual, Content field well.
	measure 'KPI Product Revenue Card' =
			VAR _v = [Product Revenue]
			VAR _py = CALCULATE ( [Product Revenue], SAMEPERIODLASTYEAR ( dim_date[Date] ) )
			VAR _delta = DIVIDE ( _v - _py, ABS ( _py ) )
			VAR _valTxt =
			    SWITCH ( TRUE (),
			        ABS ( _v ) >= 1000000, FORMAT ( _v / 1000000, "$0.00" ) & "M",
			        ABS ( _v ) >= 1000, FORMAT ( _v / 1000, "$0" ) & "K",
			        FORMAT ( _v, "$0" ) )
			VAR _chipTxt = IF ( ISBLANK ( _delta ), "n/a", FORMAT ( _delta, "+0.0%;(0.0%);0.0%" ) )
			VAR _pos = NOT ISBLANK ( _delta ) && _delta >= 0
			VAR _chipBg = IF ( ISBLANK ( _delta ), "rgb(241,245,249)", IF ( _pos, "rgb(220,242,229)", "rgb(250,226,226)" ) )
			VAR _chipFg = IF ( ISBLANK ( _delta ), "rgb(100,116,139)", IF ( _pos, "rgb(21,128,61)", "rgb(185,28,28)" ) )
			RETURN
			"<div style='font-family:""Segoe UI"", sans-serif; height:calc(100vh - 2px); box-sizing:border-box; overflow:hidden; display:flex; flex-direction:column; justify-content:center; padding:0 4px;'>"
			    & "<div style='font-size:11px; letter-spacing:1.5px; font-weight:600; color:rgb(100,116,139);'>PRODUCT REVENUE</div>"
			    & "<div style='font-size:32px; font-weight:700; color:rgb(15,23,42); line-height:1.1; margin:3px 0 9px 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;'>" & _valTxt & "</div>"
			    & "<div style='display:flex; align-items:center; gap:8px;'>"
			    & "<span style='font-size:12px; font-weight:700; color:" & _chipFg & "; background:" & _chipBg & "; border-radius:12px; padding:4px 10px; white-space:nowrap;'>" & _chipTxt & "</span>"
			    & "<span style='font-size:10.5px; color:rgb(148,163,184); white-space:nowrap;'>vs last year</span>"
			    & "</div></div>"
		displayFolder: 9. KPI Cards
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a643

	/// KPI tile (HTML): host in an HTML Content visual, Content field well.
	measure 'KPI Units Sold Card' =
			VAR _v = [Product Units]
			VAR _py = CALCULATE ( [Product Units], SAMEPERIODLASTYEAR ( dim_date[Date] ) )
			VAR _delta = DIVIDE ( _v - _py, ABS ( _py ) )
			VAR _valTxt =
			    SWITCH ( TRUE (),
			        ABS ( _v ) >= 1000000, FORMAT ( _v / 1000000, "0.00" ) & "M",
			        ABS ( _v ) >= 1000, FORMAT ( _v / 1000, "0.0" ) & "K",
			        FORMAT ( _v, "0" ) )
			VAR _chipTxt = IF ( ISBLANK ( _delta ), "n/a", FORMAT ( _delta, "+0.0%;(0.0%);0.0%" ) )
			VAR _pos = NOT ISBLANK ( _delta ) && _delta >= 0
			VAR _chipBg = IF ( ISBLANK ( _delta ), "rgb(241,245,249)", IF ( _pos, "rgb(220,242,229)", "rgb(250,226,226)" ) )
			VAR _chipFg = IF ( ISBLANK ( _delta ), "rgb(100,116,139)", IF ( _pos, "rgb(21,128,61)", "rgb(185,28,28)" ) )
			RETURN
			"<div style='font-family:""Segoe UI"", sans-serif; height:calc(100vh - 2px); box-sizing:border-box; overflow:hidden; display:flex; flex-direction:column; justify-content:center; padding:0 4px;'>"
			    & "<div style='font-size:11px; letter-spacing:1.5px; font-weight:600; color:rgb(100,116,139);'>UNITS SOLD</div>"
			    & "<div style='font-size:32px; font-weight:700; color:rgb(15,23,42); line-height:1.1; margin:3px 0 9px 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;'>" & _valTxt & "</div>"
			    & "<div style='display:flex; align-items:center; gap:8px;'>"
			    & "<span style='font-size:12px; font-weight:700; color:" & _chipFg & "; background:" & _chipBg & "; border-radius:12px; padding:4px 10px; white-space:nowrap;'>" & _chipTxt & "</span>"
			    & "<span style='font-size:10.5px; color:rgb(148,163,184); white-space:nowrap;'>vs last year</span>"
			    & "</div></div>"
		displayFolder: 9. KPI Cards
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a644

	/// KPI tile (HTML): host in an HTML Content visual, Content field well.
	measure 'KPI Vital Few Card' =
			VAR _prods = FILTER ( ALLSELECTED ( dim_product ), NOT ISBLANK ( [Product Revenue] ) )
			VAR _nAll = COUNTROWS ( _prods )
			VAR _n80 = COUNTROWS ( FILTER ( _prods, [Cumulative Revenue %] < 0.80 ) ) + 1
			VAR _share = DIVIDE ( _n80, _nAll )
			VAR _valTxt = IF ( ISBLANK ( _nAll ) || _nAll = 0, "n/a", _n80 & " SKUs" )
			VAR _chipTxt = IF ( ISBLANK ( _share ), "n/a", FORMAT ( _share, "0%" ) & " of catalog" )
			RETURN
			"<div style='font-family:""Segoe UI"", sans-serif; height:calc(100vh - 2px); box-sizing:border-box; overflow:hidden; display:flex; flex-direction:column; justify-content:center; padding:0 4px;'>"
			    & "<div style='font-size:11px; letter-spacing:1.5px; font-weight:600; color:rgb(100,116,139);'>THE VITAL FEW</div>"
			    & "<div style='font-size:32px; font-weight:700; color:rgb(15,23,42); line-height:1.1; margin:3px 0 9px 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;'>" & _valTxt & "</div>"
			    & "<div style='display:flex; align-items:center; gap:8px;'>"
			    & "<span style='font-size:12px; font-weight:700; color:rgb(21,128,61); background:rgb(220,242,229); border-radius:12px; padding:4px 10px; white-space:nowrap;'>" & _chipTxt & "</span>"
			    & "<span style='font-size:10.5px; color:rgb(148,163,184); white-space:nowrap;'>drive 80% of revenue</span>"
			    & "</div></div>"
		displayFolder: 9. KPI Cards
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a645

	/// KPI tile (HTML): host in an HTML Content visual, Content field well.
	measure 'KPI Top Product Card' =
			VAR _prods = FILTER ( ALLSELECTED ( dim_product ), NOT ISBLANK ( [Product Revenue] ) )
			VAR _topTbl = TOPN ( 1, _prods, [Product Revenue] + dim_product[ProductKey] / 1000000000, DESC )
			VAR _name = MAXX ( _topTbl, dim_product[ProductName] )
			VAR _rev = MAXX ( _topTbl, [Product Revenue] )
			VAR _share = DIVIDE ( _rev, CALCULATE ( [Product Revenue], ALLSELECTED ( dim_product ) ) )
			VAR _valTxt = IF ( ISBLANK ( _name ), "n/a", _name )
			VAR _chipTxt = IF ( ISBLANK ( _share ), "n/a", FORMAT ( _share, "0.0%" ) & " of revenue" )
			RETURN
			"<div style='font-family:""Segoe UI"", sans-serif; height:calc(100vh - 2px); box-sizing:border-box; overflow:hidden; display:flex; flex-direction:column; justify-content:center; padding:0 4px;'>"
			    & "<div style='font-size:11px; letter-spacing:1.5px; font-weight:600; color:rgb(100,116,139);'>TOP PRODUCT</div>"
			    & "<div style='font-size:19px; font-weight:700; color:rgb(15,23,42); line-height:1.1; margin:3px 0 9px 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;'>" & _valTxt & "</div>"
			    & "<div style='display:flex; align-items:center; gap:8px;'>"
			    & "<span style='font-size:12px; font-weight:700; color:rgb(180,83,9); background:rgb(255,237,213); border-radius:12px; padding:4px 10px; white-space:nowrap;'>" & _chipTxt & "</span>"
			    & "<span style='font-size:10.5px; color:rgb(148,163,184); white-space:nowrap;'>by revenue</span>"
			    & "</div></div>"
		displayFolder: 9. KPI Cards
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a646

	/// Deneb statement: pre-formatted Actual text, identical to the HTML prototype formatting.
	measure 'Line Actual Text' = IF ( ISBLANK ( [P&L Line Value] ), "-", FORMAT ( [P&L Line Value], "#,##0;(#,##0)" ) )
		displayFolder: 6. Statement Lines
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a647

	measure 'Line Budget Text' = IF ( ISBLANK ( [Budget Line Value] ), "-", FORMAT ( [Budget Line Value], "#,##0;(#,##0)" ) )
		displayFolder: 6. Statement Lines
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a648

	measure 'Line Variance Text' = IF ( ISBLANK ( [Line Variance] ), "-", FORMAT ( [Line Variance], "+#,##0;(#,##0);0" ) )
		displayFolder: 6. Statement Lines
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a649

	measure 'Line Var % Text' = IF ( ISBLANK ( [Line Variance %] ), "-", FORMAT ( [Line Variance %], "+0.0%;(0.0%);0.0%" ) )
		displayFolder: 6. Statement Lines
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a650

	/// Deneb statement: variance color as data, so the spec only draws.
	measure 'Line Variance Color' = IF ( ISBLANK ( [Line Variance] ), "#94a3b8", IF ( [Line Variance] >= 0, "#16a34a", "#dc2626" ) )
		displayFolder: 6. Statement Lines
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a651

	/// Dynamic subtitle for the Deneb statement header, same logic as the HTML prototype.
	measure 'Statement Subtitle' =
			VAR _lastClosedRaw = [Last Closed Date]
			VAR _lastClosed = IF ( ISBLANK ( _lastClosedRaw ), MAX ( dim_date[Date] ), _lastClosedRaw )
			VAR _firstData = CALCULATE ( MIN ( fact_pnl_actuals[Date] ), REMOVEFILTERS () )
			VAR _period =
			    IF (
			        HASONEVALUE ( dim_date[YearMonthKey] ),
			        SELECTEDVALUE ( dim_date[YearMonthLabel] ),
			        FORMAT ( MAX ( MIN ( dim_date[Date] ), _firstData ), "MMM YYYY" ) & " to "
			            & FORMAT ( MIN ( MAX ( dim_date[Date] ), _lastClosed ), "MMM YYYY" )
			    )
			VAR _scope =
			    SWITCH (
			        TRUE (),
			        HASONEVALUE ( dim_store[StoreName] ), SELECTEDVALUE ( dim_store[StoreName] ),
			        HASONEVALUE ( dim_store[Region] ), SELECTEDVALUE ( dim_store[Region] ) & " Region",
			        "All Stores"
			    )
			RETURN
			    _period & "  ·  " & _scope & "  ·  Actual vs Budget"
		displayFolder: 6. Statement Lines
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a652

	/// Deneb Pareto: bar color as data (vital few green inside the 80% band).
	measure 'Pareto Bar Color' = IF ( [Cumulative Revenue %] <= 0.80, "#2d6a4f", "#cbd5e1" )
		displayFolder: 5. Pareto
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a653

	/// Deneb Pareto: cumulative % label only at ranks 1, 5, 10, 15, 20.
	measure 'Pareto Cum Label' =
			IF (
			    [Product Rank] = 1 || MOD ( [Product Rank], 5 ) = 0,
			    FORMAT ( [Cumulative Revenue %], "0%" ),
			    BLANK ()
			)
		displayFolder: 5. Pareto
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a654

	/// Dynamic subtitle for the Deneb Pareto header, same logic as the HTML prototype.
	measure 'Pareto Subtitle' =
			VAR _prods = FILTER ( ALLSELECTED ( dim_product ), NOT ISBLANK ( [Product Revenue] ) )
			VAR _nAll = COUNTROWS ( _prods )
			VAR _nShown = MIN ( _nAll, 20 )
			VAR _lastClosedRaw = [Last Closed Date]
			VAR _lastClosed = IF ( ISBLANK ( _lastClosedRaw ), MAX ( dim_date[Date] ), _lastClosedRaw )
			VAR _firstData = CALCULATE ( MIN ( fact_pnl_actuals[Date] ), REMOVEFILTERS () )
			VAR _period =
			    IF (
			        HASONEVALUE ( dim_date[YearMonthKey] ),
			        SELECTEDVALUE ( dim_date[YearMonthLabel] ),
			        FORMAT ( MAX ( MIN ( dim_date[Date] ), _firstData ), "MMM YYYY" ) & " to "
			            & FORMAT ( MIN ( MAX ( dim_date[Date] ), _lastClosed ), "MMM YYYY" )
			    )
			VAR _scope =
			    SWITCH (
			        TRUE (),
			        HASONEVALUE ( dim_store[StoreName] ), SELECTEDVALUE ( dim_store[StoreName] ),
			        HASONEVALUE ( dim_store[Region] ), SELECTEDVALUE ( dim_store[Region] ) & " Region",
			        "All Stores"
			    )
			RETURN
			    "Top " & _nShown & " of " & _nAll & " products  ·  " & _period & "  ·  " & _scope
		displayFolder: 5. Pareto
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a655

	/// Dynamic insight line for the Deneb Pareto header.
	measure 'Pareto Insight' =
			VAR _prods = FILTER ( ALLSELECTED ( dim_product ), NOT ISBLANK ( [Product Revenue] ) )
			VAR _nAll = COUNTROWS ( _prods )
			VAR _n80 = COUNTROWS ( FILTER ( _prods, [Cumulative Revenue %] < 0.80 ) ) + 1
			RETURN
			    _n80 & " of " & _nAll & " products drive 80% of revenue"
		displayFolder: 5. Pareto
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a656

	column Value
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 5a1b2c3d-0003-4e5f-8a9b-c0d1e2f3a636
		summarizeBy: none
		sourceColumn: Value

		annotation SummarizationSetBy = User

	partition _Measures = m
		mode: import
		source =
				let
				    Source = #table(type table [Value = Int64.Type], {})
				in
				    Source

	annotation PBI_ResultType = Table

