# ─────────────────────────────────────────────────────────────
#  Embedded Power BI — app-owns-data + static RLS
#  Copy this file to .env and fill in real values. Do NOT commit .env.
# ─────────────────────────────────────────────────────────────

# ── Azure AD service principal ──
# App registration in Entra ID (single tenant, no redirect URI, no API permissions).
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=your-client-secret-value-not-the-secret-id

# ── Power BI target ──
# From powerbi.com URLs:
#   Workspace: app.powerbi.com/groups/<WORKSPACE_ID>/...
#   Report:    .../reports/<REPORT_ID>/...
#   Dataset:   open the semantic model → Settings, or .../datasets/<DATASET_ID>
WORKSPACE_ID=00000000-0000-0000-0000-000000000000
REPORT_ID=00000000-0000-0000-0000-000000000000
DATASET_ID=00000000-0000-0000-0000-000000000000

# ── Server / session ──
PORT=3000
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string
